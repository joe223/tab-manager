{
  "name": "tab-manager",
  "version": "1.0.0",
  "description": "Auto-group tabs by domain and close inactive tabs",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.13.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2"
  },
  "manifest": {
    "name": "Tab Manager",
    "permissions": ["tabs", "tabGroups", "storage", "alarms"]
  }
}
